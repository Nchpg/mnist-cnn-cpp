{
  "input_shape": {"channels": 1, "height": 28, "width": 28},
  "hyperparameters": {
    "batch_size": 64,
    "optimizer": {
      "type": "Adam",
      "learning_rate": 0.001,
      "beta1": 0.9,
      "beta2": 0.999,
      "epsilon": 1e-08
    }
  },
  "layers": [
    {"type": "Conv", "filters": 32, "kernel_size": 3},
    {"type": "BatchNorm"},
    {"type": "ReLU"},
    {"type": "Conv", "filters": 32, "kernel_size": 3},
    {"type": "BatchNorm"},
    {"type": "ReLU"},
    {"type": "Pool", "pool_size": 2, "stride": 2},
    {"type": "Conv", "filters": 64, "kernel_size": 3},
    {"type": "BatchNorm"},
    {"type": "ReLU"},
    {"type": "Conv", "filters": 64, "kernel_size": 3},
    {"type": "BatchNorm"},
    {"type": "ReLU"},
    {"type": "Pool", "pool_size": 2, "stride": 2},
    {"type": "Flatten"},
    {"type": "Dense", "units": 128},
    {"type": "ReLU"},
    {"type": "Dropout", "ratio": 0.5},
    {"type": "Dense", "units": 10}
  ]
}